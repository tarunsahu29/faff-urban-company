# Copy to .env and fill in.  .env is gitignored — never commit real secrets.

# ---- Urban Company session (from DevTools capture; needed for auth'd endpoints) ----
# Paste the full Cookie header value from a logged-in web session (bonus / some read paths).
UC_COOKIE=
# Some UC endpoints use bearer/x-auth tokens instead of / in addition to cookies.
UC_AUTH_TOKEN=
# City / hub context UC scopes catalog + slots to (discovered during recon).
UC_CITY=

# ---- Free-text parsing + service matching ----
# Recommended: use Gemini (handles messy sentences + picks the right UC service).
# Get a free key at https://aistudio.google.com/apikey  → paste below.
# If GEMINI_API_KEY is set, Gemini is used automatically (no need to change PARSER_BACKEND).
# Without a key it falls back to the offline heuristic parser.
PARSER_BACKEND=heuristic
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=

# ---- BONUS booking safety gate ----
# Real dispatch + payment is refused unless this is true AND the request sends confirm=true.
# Leave false; flip to true locally only for one cancellable test booking.
ALLOW_REAL_BOOKING=false

# ---- Geocoding ----
# Nominatim (fallback geocoder only) identifies clients by User-Agent. No key required.
# Don't use a placeholder email here — Nominatim 403s obviously-fake contacts.
# Leave as-is, or append your real email: "faff-urban-company-demo/1.0 (me@realdomain.com)"
NOMINATIM_USER_AGENT=faff-urban-company-demo/1.0
